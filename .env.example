# Token pricing for cost estimation in TUI footer (optional)
# Set both to display real-time cost during analysis.
# Example for GPT-4o: input $2.50 / 1M, output $10.00 / 1M
# Example for DeepSeek-V3: input $0.27 / 1M, output $1.10 / 1M
INPUT_TOKEN_PRICE_PER_1M=
OUTPUT_TOKEN_PRICE_PER_1M=

# Portfolio holdings Google Sheet (optional — avoids typing --sheet-id every time)
PORTFOLIO_SHEET_ID=

# Transaction history Google Sheet (optional — independent sheet for trade logs)
TRANSACTION_SHEET_ID=
